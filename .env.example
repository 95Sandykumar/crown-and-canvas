# Stripe (Required)
# Get your keys at: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret
# Create webhook at: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://your-domain.com/api/webhooks/stripe
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (Required)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend Email (Optional - orders logged to console without this)
# Sign up at: https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Crown & Canvas <orders@resend.dev>

# Your email address to receive order notifications
ORDER_NOTIFICATION_EMAIL=your-email@gmail.com

# Google AI / Gemini (Required for AI portrait generation)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Vercel Blob Storage (Required for photo/portrait storage)
# From Vercel project settings → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Internal API Secret (Required - secures /api/generate endpoint)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# Supabase (orders database)
# Project Settings -> API. URL is public; service_role key is SECRET (server-only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend Audience ID (customers auto-added on portrait delivery)
RESEND_AUDIENCE_ID=

# Instagram auto-posting (scripts/post-instagram.mjs + GitHub Actions)
# Requires an Instagram Business/Creator account linked to a Facebook Page,
# and a Meta app with instagram_basic + instagram_content_publish permissions.
# IG_USER_ID: your Instagram Business account id (numeric).
# IG_ACCESS_TOKEN: a long-lived access token (~60 days, refreshable).
# Get both via https://developers.facebook.com (Graph API Explorer).
# Note: BLOB_READ_WRITE_TOKEN (above) is also required — it hosts the public
# video URL the Graph API downloads.
IG_USER_ID=
IG_ACCESS_TOKEN=
